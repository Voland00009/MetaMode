# Python
.venv/
__pycache__/
*.pyc

# Runtime state (regenerated automatically)
scripts/state.json
scripts/last-flush.json
scripts/flush.log
scripts/session-flush-*.md
scripts/flush-context-*.md

# Build artifacts
dist/

# Reports (generated by lint)
reports/

# Runtime data (regenerated by hooks)
scripts/pending-review.md
scripts/compile.log

# Editor
.vscode/
.idea/

# Obsidian
.obsidian/
knowledge/.obsidian/
*.base
*.canvas

# OS
.DS_Store
Thumbs.db

# Claude Code local settings
.claude/settings.local.json

# Media files (hosted on GitHub Releases, not in git)
media/

# Personal wiki content — keep folder structure via .gitkeep, ignore the content
# (users' own daily logs, compiled wiki, raw inbox, and plans stay local)
daily/*
!daily/.gitkeep

raw/*
!raw/.gitkeep

plans/*
!plans/.gitkeep

knowledge/*
!knowledge/concepts/
!knowledge/connections/
!knowledge/qa/
knowledge/concepts/*
!knowledge/concepts/.gitkeep
knowledge/connections/*
!knowledge/connections/.gitkeep
knowledge/qa/*
!knowledge/qa/.gitkeep

# memory/ is not a project folder — hooks write to ~/.claude/projects/*/memory/
memory/
